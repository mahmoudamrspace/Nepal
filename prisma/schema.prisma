// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

enum PackageCategory {
  Adventure
  Culture
  Relaxation
  Wellness
}

enum Difficulty {
  Easy
  Moderate
  Challenging
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum PaymentMethod {
  credit_card
  bank_transfer
  paypal
}

enum ReviewPlatform {
  Google
  TripAdvisor
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Author {
  id        String     @id @default(cuid())
  name      String     @unique
  avatar    String?
  bio       String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  blogPosts BlogPost[]

  @@map("authors")
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  color     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  blogPosts BlogPost[]
  packages  Package[]

  @@map("tags")
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String    @db.Text
  content       String    @db.Text
  featuredImage String
  images        String[]
  authorId      String
  author        Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      String
  tags          Tag[]
  publishedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
  featured      Boolean   @default(false)
  views         Int       @default(0)
  seoTitle      String?
  seoDescription String?  @db.Text
  readingTime   Int       @default(5)

  @@index([slug])
  @@index([publishedAt])
  @@index([featured])
  @@map("blog_posts")
}

model Package {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  shortDescription String       @db.Text
  fullDescription String        @db.Text
  price           Float
  currency        String        @default("USD")
  duration        String
  location        String
  difficulty      Difficulty
  groupSize       Int
  images          String[]
  featuredImage   String
  category        PackageCategory
  featured        Boolean       @default(false)
  availableDates  String[]
  itinerary       Json          // Array of ItineraryDay objects
  included        String[]
  excluded        String[]
  faq             Json          // Array of FAQ objects
  highlights      String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bookings        Booking[]
  tags            Tag[]

  @@index([slug])
  @@index([category])
  @@index([featured])
  @@index([price])
  @@map("packages")
}

model Booking {
  id                String        @id @default(cuid())
  bookingNumber     String        @unique
  packageId         String
  package           Package       @relation(fields: [packageId], references: [id], onDelete: Restrict)
  travelers         Json          // Array of Traveler objects
  selectedDate      String
  numberOfTravelers Int
  basePrice         Float
  taxes             Float
  fees              Float
  totalPrice        Float
  currency          String        @default("USD")
  status            BookingStatus @default(pending)
  paymentStatus     PaymentStatus @default(pending)
  paymentMethod     PaymentMethod?
  customerEmail     String
  customerPhone     String
  specialRequests   String?       @db.Text
  emergencyContact  Json?         // Emergency contact object
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([bookingNumber])
  @@index([packageId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("bookings")
}

model Review {
  id            String         @id @default(cuid())
  platform      ReviewPlatform
  reviewerName  String
  reviewerAvatar String?
  rating        Int
  reviewText    String         @db.Text
  date          DateTime
  reviewUrl     String?
  verified      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([platform])
  @@index([rating])
  @@map("reviews")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([email])
  @@index([createdAt])
  @@map("contact_submissions")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  subscribedAt DateTime @default(now())
  active    Boolean  @default(true)

  @@index([email])
  @@map("newsletter_subscribers")
}
